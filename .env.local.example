# Local development config — copy to .env.local then run: npm run setup:local

# Turso (local SQLite file — no auth token needed)
TURSO_DATABASE_URL=file:.data/local.db

# MinIO (local S3-compatible storage — start with: docker compose up -d)
S3_ENDPOINT=http://127.0.0.1:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=cms-uploads
R2_PUBLIC_URL=http://127.0.0.1:9000/cms-uploads

# Auth (required even in dev for login to work)
AUTH_SECRET=local-dev-secret-change-in-production

# Seed admin user (uncomment and set, then run: npm run db:seed)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=your-password
