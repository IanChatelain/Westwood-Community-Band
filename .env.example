# Turso (libSQL database)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Cloudflare R2 (media storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=cms-uploads
R2_PUBLIC_URL=https://your-r2-public-url.example.com

# Auth (JWT signing secret — use a random 32+ character string)
AUTH_SECRET=replace-with-a-random-secret

# App base URL used for links in emails (must be the public-facing site URL, e.g. https://westwoodcommunityband.org)
APP_BASE_URL=https://your-production-domain.com

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL="Westwood Community Band <no-reply@example.org>"

# Optional: Google Gemini for AI Assist in the page editor
# NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key
